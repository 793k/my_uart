{
  "$schema": "https://app.kilo.ai/config.json",

  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",

  "skills": {
    "paths": [
      ".kilo/skills",
      "//192.168.2.16/public/AI/skills"
    ]
  },

  "instructions": [],

  "permission": {
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "edit": {
      "src/**": "allow",
      "*": "ask"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "skill": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "lsp": "allow"
  },

  "agent": {
    "code": {
      "model": "deepseek/deepseek-v4-pro"
    },
    "ask": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "plan": {
      "model": "deepseek/deepseek-v4-pro"
    },
    "debug": {
      "model": "deepseek/deepseek-v4-pro"
    },
    "orchestrator": {
      "model": "deepseek/deepseek-v4-pro"
    }
  }
}
